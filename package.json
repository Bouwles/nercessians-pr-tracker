{
  "name": "nercessians-pr-tracker",
  "version": "1.0.0",
  "description": "Track your personal records and gym progress",
  "main": "src/main/main.js",
  "scripts": {
    "start": "concurrently \"npm run webpack:dev\" \"wait-on file:dist/index.html && electron .\"",
    "webpack:dev": "webpack --watch --mode development",
    "webpack:build": "webpack --mode production",
    "build": "npm run webpack:build && electron-builder --win",
    "pack": "npm run webpack:build && electron-builder --win --dir"
  },
  "build": {
    "appId": "com.nercessian.prtracker",
    "productName": "Nercessian's PR Tracker",
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Nercessian's PR Tracker"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/preset-env": "^7.23.7",
    "@babel/preset-react": "^7.23.3",
    "autoprefixer": "^10.4.17",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.9.1",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "html-webpack-plugin": "^5.6.0",
    "postcss": "^8.4.33",
    "postcss-loader": "^7.3.4",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.1",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
